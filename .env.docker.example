# Copy to .env and replace every placeholder before running docker compose.

REPOINTEL_POSTGRES_PASSWORD=repointel
REPOINTEL_GERRIT_URL=https://gerrit.example.org
REPOINTEL_GIT_ROOT_HOST=./.repointel-git

REPO_INTEL_SESSION_SECRET=replace-with-64-plus-random-hex-chars
REPO_INTEL_COOKIE_SECURE=false
REPO_INTEL_BOOTSTRAP_ADMIN_USERNAME=admin
REPO_INTEL_BOOTSTRAP_ADMIN_PASSWORD=change-me-now

REPO_INTEL_OIDC_ISSUER_URL=
REPO_INTEL_OIDC_CLIENT_ID=
REPO_INTEL_OIDC_CLIENT_SECRET=
REPO_INTEL_OIDC_REDIRECT_URI=

METADATA_COLLECTION_READER_TOKEN=local-metadata-reader-token-change-me
METADATA_COLLECTION_WRITER_TOKEN=local-metadata-writer-token-change-me
METADATA_COLLECTION_ADMIN_TOKEN=local-metadata-admin-token-change-me
METADATA_COLLECTION_AUTH_TOKENS_JSON={"tokens":{"local-metadata-reader-token-change-me":{"subject_id":"gateway-reader","handle":"gateway-reader","roles":["reader"]},"local-metadata-writer-token-change-me":{"subject_id":"gateway-writer","handle":"gateway-writer","roles":["writer"]},"local-metadata-admin-token-change-me":{"subject_id":"gateway-admin","handle":"gateway-admin","roles":["admin"]}}}
METADATA_COLLECTION_GATEWAY_TOKEN=local-metadata-reader-token-change-me
METADATA_COLLECTION_REPOINTEL_TOKEN=roles=writer

REPOINTEL_READER_TOKEN=roles=reader
REPOINTEL_WRITER_TOKEN=roles=writer
REPOINTEL_ADMIN_TOKEN=roles=admin

REPOINTEL_ANALYTICS_PROVIDER_TOKEN=replace-with-analytics-provider-token
REPOINTEL_SZZ_PROVIDER_TOKEN=replace-with-szz-provider-token
